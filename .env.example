# Copy to .env for local runs (never commit the real .env).
# On a host (Railway/Render/Fly/GitHub Actions) set these as secrets/vars instead.

RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# JSON secret-key array of the low-privilege keeper wallet (the [12,34,...] from keeper.json)
KEEPER_SECRET=[12,34,56]
# optional overrides
# IDL_PATH=./solotto_raffle.json
# KEEPER_INTERVAL_MS=60000
