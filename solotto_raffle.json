  "instructions": [
    {
      "name": "buy_tickets",
      "docs": [
        "Buy `quantity` tickets in a single transaction. More tickets = more",
        "weight in the draw. SOL is moved into the raffle PDA via a CPI to the",
        "system program; we track the running pool in `prize_pool`."
      ],
